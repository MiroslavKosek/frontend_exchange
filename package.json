{
  "name": "frontend-exchange",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "eslint \"src/**/*.{ts,html}\" --no-fix --max-warnings 0",
    "extract": "ngx-translate-extract --input ./src --output ./public/i18n/{en,cs}.json --clean --sort --format json --marker _, TRANSLATE, translate",
    "pretranslate": "angular-gettext-cli --files \"./src/**/*.+(html|ts)\" --exclude \"**/*.spec.ts\" --dest \"./public/i18n/extract.pot\" --marker-names \"_,instant,translate\" --attribute translate",
    "translate": "msgmerge -s ./public/i18n/cs.po ./public/i18n/extract.pot -o ./public/i18n/cs.po && msgmerge -s ./public/i18n/en.po ./public/i18n/extract.pot -o ./public/i18n/en.po",
    "posttranslate": "node ./scripts/i18n-po-to-json.mjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/common": "^21.2.1",
    "@angular/compiler": "^21.2.1",
    "@angular/core": "^21.2.1",
    "@angular/forms": "^21.2.1",
    "@angular/platform-browser": "^21.2.1",
    "@angular/router": "^21.2.1",
    "@biesbjerg/ngx-translate-extract-marker": "^1.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@primeuix/themes": "^2.0.3",
    "chart.js": "^4.5.1",
    "ngx-logger": "^5.0.12",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "vitest-canvas-mock": "^1.1.3"
  },
  "devDependencies": {
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.1",
    "@angular/language-service": "^21.2.1",
    "@eslint/js": "^10.0.1",
    "@ngx-translate/core": "^17.0.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@vendure/ngx-translate-extract": "10.1.2",
    "@vitest/coverage-v8": "^4.0.18",
    "angular-eslint": "^21.3.0",
    "angular-gettext-cli": "^1.2.0",
    "eslint": "^10.0.3",
    "jsdom": "^28.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  }
}
